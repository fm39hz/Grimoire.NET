{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"ConnectionStrings": {
		"Postgre": ""
	},
	"OpenApi": {
		"ServerUrl": ""
	},
	"Storage": {
		"Type": "S3",
		"BasePath": "grimoire",
		"SeriesPath": "series",
		"UseTemporaryDirectory": false
	},
	"Serilog": {
		"Using": [
			"Serilog.Sinks.Console",
			"Serilog.Sinks.File",
			"Serilog.Enrichers.Environment",
			"Serilog.Enrichers.Thread",
			"Serilog.Settings.Configuration"
		],
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Information",
				"System": "Warning"
			}
		},
		"Enrich": [
			"FromLogContext",
			"WithExceptionDetails",
			"WithMachineName",
			"WithThreadId"
		],
		"WriteTo": [
			{
				"Name": "File",
				"Args": {
					"path": "logs/Job.Recovery.log",
					"rollingInterval": "Day",
					"retainedFileCountLimit": 15,
					"shared": true,
					"flushToDiskInterval": "00:00:01",
					"outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
				}
			}
		]
	},
	"AllowedHosts": "*"
}
